{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "oracle": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": []
    },
    "explore": {
      "model": "ollama/qwen3.5-9b-sushi-coder:latest",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "multimodal-looker": {
      "model": "google/gemini-3.1-pro-preview",
      "fallback_models": []
    },
    "prometheus": {
      "model": "opencode/qwen3.6-plus-free",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "metis": {
      "model": "ollama/mistral-nemo:12b",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "momus": {
      "model": "opencode/qwen3.6-plus-free",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ],
      "variant": "high"
    },
    "atlas": {
      "model": "ollama/qwen3.5:9b",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "sisyphus-junior": {
      "model": "ollama/qwen3.5-9b-sushi-coder:latest",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "sisyphus": {
      "model": "google/gemini-3.1-pro-preview",
      "fallback_models": [
        "ollama/qwen3.5:9b"
      ]
    },
    "librarian": {
      "model": "ollama/mistral-nemo:12b",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "hephaestus": {
      "model": "ollama/qwen3.5-9b-sushi-coder:latest",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ],
      "options": {
        "stop": [
          "<|endoftext|>",
          "<|im_end|>",
          "}"
        ],
        "format": "json",
        "temperature": 0.2
      }
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "ollama/gemma4:e4b",
      "variant": "high",
      "description": "Frontend e UI/UX",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "ultrabrain": {
      "model": "opencode/qwen3.6-plus-free",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ],
      "variant": "high"
    },
    "deep": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "description": "Ricerca profonda e debugging complesso",
      "fallback_models": []
    },
    "artistry": {
      "model": "ollama/gemma4:e4b",
      "variant": "high",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "quick": {
      "model": "ollama/qwen3.5-9b-sushi-coder:latest",
      "description": "Task banali: typo, modifiche file singolo",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "unspecified-low": {
      "model": "ollama/mistral-nemo:12b",
      "description": "Task generici a basso sforzo",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "unspecified-high": {
      "model": "ollama/qwen3.5:9b",
      "description": "Task complessi: refactoring multi-file",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    },
    "writing": {
      "model": "ollama/mistral-nemo:12b",
      "description": "Documentazione e README",
      "fallback_models": [
        "google/gemini-3.1-pro-preview"
      ]
    }
  },
  "background_task": {
    "defaultConcurrency": 4,
    "providerConcurrency": {
      "ollama": 2,
      "google": 2
    },
    "modelConcurrency": {
      "google/gemini-3.1-pro-preview": 1,
      "ollama/qwen3.5-9b-sushi-coder:latest": 1,
      "ollama/qwen3.5:9b": 1,
      "ollama/mistral-nemo:12b": 1,
      "ollama/gemma4:e4b": 1
    }
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "skills": {
    "sources": [
      {
        "path": "${HOME}/.config/opencode/skill",
        "recursive": true
      }
    ],
    "archive": {
      "index": "${HOME}/opencode-ecosystem/skills/.archive-index.json",
      "activate_script": "${HOME}/opencode-ecosystem/skills/activate-skill",
      "deactivate_script": "${HOME}/opencode-ecosystem/skills/deactivate-skill"
    }
  },
  "mcp": {
    "codemem": {
      "command": [
        "node",
        "${HOME}/opencode-ecosystem/codemem/packages/mcp-server/dist/index.js"
      ],
      "env": {
        "NODE_ENV": "production"
      },
      "description": "CodeMEM - AST-guided long-term memory"
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "truncate_all_tool_outputs": false
  },
  "logging": {
    "enabled": true,
    "level": "info",
    "file": "${HOME}/opencode-ecosystem/oh-my-openagent/logs/orchestrator.log",
    "max_size_mb": 50,
    "max_backups": 5,
    "format": "json"
  },
  "disabled_hooks": [
    "startup-toast"
  ]
}